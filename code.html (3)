<!DOCTYPE html>
<html>
<head>
    <title>Admin Panel</title>
    <link rel="stylesheet" href="../assets/css/style.css">
</head>
<body>
    <div class="container py-5">
        <div class="glass p-5 text-center mb-5">
            <h1 class="display-4"><i class="fas fa-crown text-warning"></i> Admin Panel</h1>
            <div id="authStatus">লগইন করুন</div>
        </div>
        
        <div class="row">
            <div class="col-md-4">
                <a href="orders.html" class="glass p-4 text-center text-decoration-none mb-4 d-block">
                    <i class="fas fa-list fa-3x text-primary mb-3"></i>
                    <h5>অর্ডারস</h5>
                </a>
            </div>
            <div class="col-md-4">
                <a href="packages.html" class="glass p-4 text-center text-decoration-none mb-4 d-block">
                    <i class="fas fa-box fa-3x text-success mb-3"></i>
                    <h5>প্যাকেজ ম্যানেজ</h5>
                </a>
            </div>
            <div class="col-md-4">
                <a href="#" class="glass p-4 text-center text-decoration-none mb-4 d-block" onclick="logout()">
                    <i class="fas fa-sign-out-alt fa-3x text-danger mb-3"></i>
                    <h5>লগআউট</h5>
                </a>
            </div>
        </div>
    </div>

    <script type="module">
        import { auth, onAuthStateChanged, signOut } from '../assets/js/firebase.js';
        
        onAuthStateChanged(auth, (user) => {
            if(user && user.email === 'admin@topup.com') {
                document.getElementById('authStatus').innerHTML = `স্বাগতম ${user.email}`;
            } else {
                window.location.href = '../index.html';
            }
        });
        
        window.logout = () => {
            signOut(auth);
        };
    </script>
</body>
</html>
